  <x:String x:Key="GameModeToolTip">Oyunu seç</x:String>
  <x:String x:Key="PresetToolTip">Ön ayar seç</x:String>
  <x:String x:Key="ClusterUnclusterToolTip">Sunucuları grupla veya gruplamayı kaldır</x:String>
  <x:String x:Key="RefreshToolTip">Tüm sunucu gecikmelerini yenile</x:String>
