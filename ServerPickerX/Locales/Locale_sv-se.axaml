  <x:String x:Key="NewPresetName">Ny förinställning</x:String>
  <x:String x:Key="AddPresetToolTip">Skapa en ny förinställning</x:String>
  <x:String x:Key="DeletePreset">Ta bort</x:String>
  <x:String x:Key="DeletePresetToolTip">Ta bort markerade förinställningar</x:String>
