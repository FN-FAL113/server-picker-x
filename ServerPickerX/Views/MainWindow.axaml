<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ServerPickerX.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:ServerPickerX.Converters"
        xmlns:userControls="using:ServerPickerX"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        mc:Ignorable="d"
        x:Class="ServerPickerX.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Server Picker X"
        FontWeight="SemiBold"
        Width="920"
        Height="640"
        Icon="/Assets/favicon.ico"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:ImageConverter x:Key="ImageConverter" />
        <converters:PacketLossColorConverter x:Key="PacketLossColorConverter" />
        <converters:PingColorConverter x:Key="PingColorConverter" />
    </Window.Resources>

    <Border
        Background="#373B78"
        BorderBrush="#575cd4"
        BorderThickness="1.0">
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="30" />
                <!-- Main Content -->
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" x:Name="TitleBar" Background="#373B78" PointerPressed="TitleBar_PointerPressed" >
                <ProgressBar 
                    Margin="0,-28,0,0" 
                    Height="6"
                    Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=Width}"
                    IsIndeterminate="True"
                    IsVisible="{Binding ShowProgressBar}"/>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
				<Grid.RowDefinitions>
                    <!-- Top Buttons -->
					<RowDefinition Height="48"></RowDefinition>
                    <!-- Server DataGrid -->
					<RowDefinition></RowDefinition>
                    <!-- Main Buttons -->
                    <RowDefinition Height="48"></RowDefinition>
                    <!-- Footer -->
					<RowDefinition Height="48"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBox
                            Classes="search-textbox"
                            Text="{Binding SearchText}"
                            IsEnabled="{Binding IsOperationAllowed}"
                            Watermark="{DynamicResource SearchForServers}"
                            FontSize="12"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Width="144"
                            Margin="8,0,0,0"
                            BorderThickness="1"/>
                        <ComboBox 
                            x:Name="GameModeComboBox" 
                            Classes="game-combobox"
                            SelectionChanged="GameModeComboBox_SelectionChanged"
                            IsEnabled="{Binding IsOperationAllowed}"
                            ToolTip.Tip="{DynamicResource GameModeToolTip}"
                            ToolTip.ShowDelay="20"
                            FontSize="12"
                            VerticalAlignment="Center"
                            Width="158"
                            Margin="8,0,0,0"
                            BorderThickness="1">
                        </ComboBox>
                        <Grid MinWidth="146" Margin="8,0,20,0">
                            <ComboBox
                                x:Name="PresetComboBox"
                                Classes="game-combobox"
                                ItemsSource="{Binding PresetItems}"
                                SelectedItem="{Binding SelectedPreset}"
                                SelectionChanged="PresetComboBox_SelectionChanged"
                                IsVisible="{Binding HasPresets}"
                                IsEnabled="{Binding CanSelectPresets}"
                                ToolTip.Tip="{DynamicResource PresetToolTip}"
                                ToolTip.ShowDelay="20"
                                FontSize="12"
                                Width="146"
                                MinWidth="146"
                                Height="32"
                                VerticalAlignment="Center"
                                BorderThickness="1">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                            <Border
                                IsVisible="{Binding !HasPresets}"
                                Width="146"
                                MinWidth="146"
                                Height="32"
                                VerticalAlignment="Center"
                                BorderBrush="#575cd4"
                                BorderThickness="1"
                                Background="#804a4e8a"
                                CornerRadius="2">
                                <TextBlock
                                    Margin="12,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="White"
                                    Opacity="0.55"
                                    TextTrimming="CharacterEllipsis"
                                    Text="{DynamicResource NoPresets}" />
                            </Border>
                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button 
                            x:Name="ClusterUnclusterBtn"
                            Classes="main-btn"
                            IsEnabled="{Binding IsOperationAllowed}"
                            Content="{DynamicResource ClusterServers}"
                            ToolTip.Tip="{DynamicResource ClusterUnclusterToolTip}"
                            ToolTip.ShowDelay="20"
                            Click="ClusterUnclusterBtn_Click"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Margin="0,0,8,0"/>
                        <Button
                            x:Name="PresetsBtn"
                            Classes="main-btn"
                            IsEnabled="{Binding IsOperationAllowed}"
                            Content="{DynamicResource Presets}"
                            ToolTip.Tip="{DynamicResource PresetsToolTip}"
                            ToolTip.ShowDelay="20"
                            Click="PresetsBtn_Click"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Margin="0,0,8,0"/>
                        <Button 
                            x:Name="RefreshBtn"
                            Classes="main-btn"
                            Command="{Binding PingServers}" 
                            CommandParameter="{Binding ServerModels}"
                            IsEnabled="{Binding IsOperationAllowed}"
                            Content="{DynamicResource Refresh}"
                            ToolTip.Tip="{DynamicResource RefreshToolTip}"
                            ToolTip.ShowDelay="20"
                            VerticalAlignment="Center"
                            Foreground="White"
                            Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                     <DataGrid
                         x:Name="ServerList"
                         ItemsSource="{Binding FilteredServerModels}"
                         SelectedItem="{Binding SelectedDataGridServerModel}"
                         SelectionMode="Extended"
                         IsReadOnly="True"
                         CanUserReorderColumns="False"
                         CanUserResizeColumns="False"
                         CanUserSortColumns="True"
                         GridLinesVisibility="All"
                         Foreground="White"
                         Background="Transparent"
                         DoubleTapped="DataGrid_DoubleTapped">
                         <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Flag">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Flag, Converter={StaticResource ImageConverter}}" 
                                               Width="50" Height="50" 
                                               Stretch="Uniform"
                                               VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
							<DataGridTextColumn Width="105" Header="Server ID" Binding="{Binding Name}" />
							<DataGridTextColumn Width="*" Header="Server Name" Binding="{Binding Description}" />
							<DataGridTemplateColumn Header="Ping" SortMemberPath="Ping" Width="128" HeaderPointerPressed="DataGridPingColumn_HeaderPointerPressed">
                                <DataGridTemplateColumn.CellTemplate>
							        <DataTemplate>
							            <TextBlock 
                                            Text="{Binding Ping}"
                                            Foreground="{Binding Ping, Converter={StaticResource PingColorConverter}}"
                                            VerticalAlignment="Center"
                                            Padding="12,0,0,0"/>
							        </DataTemplate>
							    </DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
                             <DataGridTemplateColumn Header="Packet Loss" SortMemberPath="PacketLoss" Width="120" HeaderPointerPressed="DataGridPacketLossColumn_HeaderPointerPressed">
							    <DataGridTemplateColumn.CellTemplate>
							        <DataTemplate>
							            <TextBlock 
                                            Text="{Binding PacketLoss}"
                                            Foreground="{Binding PacketLoss, Converter={StaticResource PacketLossColorConverter}}"
                                            VerticalAlignment="Center"
                                            Padding="12,0,0,0"/>
							        </DataTemplate>
							    </DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
							<DataGridTextColumn Width="100" Header="Status" Binding="{Binding Status}" />
						</DataGrid.Columns>

						<DataGrid.Styles>
                            <Style Selector="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="White" />
                            </Style>
                        </DataGrid.Styles>
                    </DataGrid>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,-6">
                      <StackPanel
                          Orientation="Horizontal" 
                          VerticalAlignment="Center" 
                          HorizontalAlignment="Left" 
                          Spacing="6" 
                          Margin="8,0,0,0">
                          <Button x:Name="BlockAllBtn"
                              Classes="main-btn"
                              IsEnabled="{Binding IsOperationAllowed}"
                              Command="{Binding BlockAllAsync}"
                              VerticalAlignment="Center"
                              MaxWidth="200"
                              ToolTip.Tip="{DynamicResource BlockAll}"
                              ToolTip.ShowDelay="20">
                              <TextBlock FontWeight="Bold">
                                  <i:Icon Value="fa-x" FontSize="14" Margin="0,0,0,-3" /> 
                                  <TextBlock Text="{DynamicResource BlockAll}" Margin="0,0,0,-4"/>
                              </TextBlock>
                          </Button>
                          <Button 
                              x:Name="BlockSelectedBtn" 
                              Classes="main-btn" 
                              IsEnabled="{Binding IsOperationAllowed}"
                              Command="{Binding BlockSelectedAsync}"
                              CommandParameter="{Binding ElementName=ServerList, Path=SelectedItems}"
                              VerticalAlignment="Center"
                              MaxWidth="200"
                              ToolTip.Tip="{DynamicResource BlockSelected}"
                              ToolTip.ShowDelay="20">
                              <TextBlock FontWeight="Bold">
                                  <i:Icon Value="fa-x" FontSize="14" Margin="0,0,0,-3" /> 
                                  <TextBlock Text="{DynamicResource BlockSelected}" Margin="0,0,0,-4"/>
                              </TextBlock>
                          </Button>
                      </StackPanel>
                      <StackPanel 
                          Orientation="Horizontal" 
                          VerticalAlignment="Center" 
                          HorizontalAlignment="Right" 
                          Spacing="6" 
                          Margin="0,0,8,0">
                          <Button 
                              x:Name="UnlockAllBtn" 
                              Classes="main-btn"
                              IsEnabled="{Binding IsOperationAllowed}"
                              Command="{Binding UnblockAllAsync}"
                              VerticalAlignment="Center"
                              MinWidth="100"
                              MaxWidth="200"
                              ToolTip.Tip="{DynamicResource UnblockAll}"
                              ToolTip.ShowDelay="20">
                              <TextBlock FontWeight="Bold">
                                  <i:Icon Value="fa-check" FontSize="14" Margin="0,0,0,-3" /> 
                                  <TextBlock Text="{DynamicResource UnblockAll}" Margin="0,0,0,-4"/>
                              </TextBlock>
                          </Button>
                          <Button 
                              x:Name="UnblockSelectedBtn" 
                              Classes="main-btn"
                              IsEnabled="{Binding IsOperationAllowed}"
                              Command="{Binding UnblockSelectedAsync}"
                              CommandParameter="{Binding ElementName=ServerList, Path=SelectedItems}"
                              VerticalAlignment="Center"
                              MinWidth="100"
                              MaxWidth="200"
                              ToolTip.Tip="{DynamicResource UnblockSelected}"
                              ToolTip.ShowDelay="20">
                              <TextBlock FontWeight="Bold">
                                  <i:Icon Value="fa-check" FontSize="14" Margin="0,0,0,-3" /> 
                                  <TextBlock Text="{DynamicResource UnblockSelected}" Margin="0,0,0,-4"/>
                              </TextBlock>
                          </Button>
                      </StackPanel>
                  </Grid>

                <Grid Grid.Row="3">
                    <userControls:FooterButtons />
                </Grid>
            </Grid>
                
        </Grid>
    </Border>


</Window>
